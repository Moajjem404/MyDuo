<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/animated_gradient">

    <!-- Header Toolbar -->
    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <!-- Hamburger Icon -->
        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/white"
            android:contentDescription="Menu" />

        <!-- Title and Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duo"
                    android:textSize="22sp"
                    android:textColor="#FF4081"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Status Indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <View
                    android:id="@+id/view_online_indicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="#00FF00" />

                <TextView
                    android:id="@+id/tv_partner_online_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Online"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right App Logo Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/app_logo"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
            app:strokeColor="#FF4081"
            app:strokeWidth="1dp"
            android:scaleType="centerCrop"
            android:contentDescription="App Logo" />

    </RelativeLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/glass_card"
        android:backgroundTint="@color/glass_card_bg_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Home Tab -->
        <LinearLayout
            android:id="@+id/tab_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#FF4081" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#FF4081"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- History Tab -->
        <LinearLayout
            android:id="@+id/tab_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:tint="@color/gray_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textSize="11sp"
                android:textColor="@color/gray_light"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Settings Tab -->
        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="@color/gray_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="11sp"
                android:textColor="@color/gray_light"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Profile Tab -->
        <LinearLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="@color/gray_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="@color/gray_light"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:layout_above="@id/bottom_nav"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Circular Image Avatar Frame -->
            <FrameLayout
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_marginTop="24dp">

                <!-- Glow background ring -->
                <View
                    android:id="@+id/pulse_ring"
                    android:layout_width="188dp"
                    android:layout_height="188dp"
                    android:layout_gravity="center"
                    android:background="@drawable/splash_glow_ring"
                    android:alpha="0.5" />

                <!-- Circular Avatar -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_partner_avatar"
                    android:layout_width="164dp"
                    android:layout_height="164dp"
                    android:layout_gravity="center"
                    android:src="@drawable/app_logo"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    app:strokeColor="#FF4081"
                    app:strokeWidth="3dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Partner Avatar" />

                <!-- Floating top-right heart badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💗"
                    android:textSize="24sp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp" />
            </FrameLayout>

            <!-- Status Text "Partner is using" -->
            <TextView
                android:id="@+id/tv_partner_current_app"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partner is using"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp" />

            <!-- Active App Card (Chrome, etc.) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:padding="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_app_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    app:strokeColor="#FF4081"
                    app:strokeWidth="1.5dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Active App Icon" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tv_app_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chrome"
                        android:textSize="22sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_partner_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Since 2 min ago"
                        android:textSize="14sp"
                        android:textColor="#FF4081"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Last App Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:paddingVertical="12dp"
                android:paddingHorizontal="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_last_app_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_compass"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    android:scaleType="centerCrop"
                    android:contentDescription="Last App Icon" />

                <TextView
                    android:id="@+id/tv_last_app_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Last app: Facebook"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_last_app_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 min ago"
                    android:textColor="@color/gray_light"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Under Development Disclaimer Notice -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:backgroundTint="#26FF4081"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="20sp"
                    android:layout_gravity="top" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beta Disclaimer"
                        android:textColor="#FF4081"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MyDuo is under active development. Sometimes incorrect information may be displayed. We are continuously improving the real-time synchronization. Thank you! 💗"
                        android:textColor="#E0E0E0"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.15" />
                </LinearLayout>
            </LinearLayout>

            <!-- Spacing to push credit down -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

            <!-- Custom Styled Footer Credit -->
            <LinearLayout
                android:id="@+id/tv_footer_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="#FF4081"
                    android:alpha="0.8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💗"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp" />

                <TextView
                    android:id="@+id/tv_footer_credit_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💗"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="1dp"
                    android:background="#FF4081"
                    android:alpha="0.8" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Full-screen No Internet Overlay -->
    <RelativeLayout
        android:id="@+id/layout_no_internet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60A0A0E"
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:backgroundTint="#26FF4081"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="50sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Connection"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please check your internet connection."
                android:textColor="@color/gray_light"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/btn_retry_internet"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="Retry"
                android:textColor="@color/white"
                app:cornerRadius="24dp"
                android:backgroundTint="@color/romantic_pink" />

        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>

