<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/setup_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/animated_gradient"
    android:padding="24dp">

    <!-- Scrollable container for forms -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/tv_setup_footer"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Heart Icon and Title -->
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/app_logo"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                app:strokeColor="@color/romantic_pink"
                app:strokeWidth="2dp"
                android:scaleType="centerCrop"
                android:contentDescription="App Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MyDuo Setup"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay Connected Forever ❤️"
                android:textSize="14sp"
                android:textColor="@color/gray_light"
                android:layout_marginTop="4dp" />

            <!-- Watch Tutorial Card -->
            <LinearLayout
                android:id="@+id/card_watch_tutorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/glass_card"
                android:backgroundTint="#26FF4081"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺"
                    android:textSize="24sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Watch Tutorial"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap here to watch setup video guide 🎬"
                        android:textColor="@color/romantic_light_pink"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➔"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Glassmorphic Input Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Bot Token Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Telegram Bot Token"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_bot_token"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:hint="123456789:ABCdefGhIJKlmNoPQRsT"
                    android:textColorHint="@color/gray_dark"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/glass_card"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <!-- Chat ID Input -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Add your Chat ID"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_group_id"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:hint="e.g. -100123456789 or 12345678"
                    android:textColorHint="@color/gray_dark"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/glass_card"
                    android:inputType="text"
                    android:singleLine="true" />

                <!-- Partner Display Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Partner Name"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_partner_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:hint="e.g. Honey / Sweetie"
                    android:textColorHint="@color/gray_dark"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/glass_card"
                    android:inputType="textPersonName"
                    android:singleLine="true" />

                <!-- Gender Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Your Gender"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb_male"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Male"
                        android:textColor="@color/white"
                        android:buttonTint="@color/romantic_light_pink"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_female"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Female"
                        android:textColor="@color/white"
                        android:buttonTint="@color/romantic_light_pink" />
                </RadioGroup>

                <!-- Dynamic Generated Sender ID Display -->
                <TextView
                    android:id="@+id/tv_generated_sender_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sender ID: Moajjem4821"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="8dp"
                    android:background="@drawable/glass_card" />

            </LinearLayout>

            <!-- Help Link -->
            <TextView
                android:id="@+id/tv_setup_help"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Need Help? View Setup Guide"
                android:textColor="@color/romantic_light_pink"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp" />

            <!-- Action Button & Loader -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Save &amp; Connect"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    android:backgroundTint="@color/romantic_pink" />

                <ProgressBar
                    android:id="@+id/pb_loader"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerInParent="true"
                    android:visibility="gone"
                    android:indeterminateTint="@color/white" />
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Footer Credit -->
    <LinearLayout
        android:id="@+id/tv_setup_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|center_horizontal"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#FF4081"
            android:alpha="0.8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💗"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_setup_footer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💗"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#FF4081"
            android:alpha="0.8" />

    </LinearLayout>

</RelativeLayout>
