<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/instructions_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/animated_gradient"
    android:padding="24dp">

    <!-- Header Toolbar -->
    <LinearLayout
        android:id="@+id/instructions_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/glass_card"
            android:backgroundTint="@color/glass_card_bg"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/white"
            android:contentDescription="Back"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Guide"
            android:textSize="22sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/instructions_header"
        android:layout_above="@+id/tv_instructions_footer"
        android:layout_marginTop="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Step 1: Telegram Group -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 1: Create a Telegram Group"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Go to Telegram and create a new Group (e.g., 'MyDuo'). Add both yourself and your partner to this group."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Step 2: Telegram Bot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 2: Create a Bot via @BotFather"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Search for @BotFather in Telegram and send /newbot.\n2. Enter a name and username for your bot.\n3. BotFather will provide an HTTP API Token. Copy this Token."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Step 3: Admin & Pin Permissions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 3: Add Bot to Group as Admin"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add your bot to the Telegram group you created. Promote it to Administrator and ensure the 'Pin Messages' permission is enabled. The app relies on this permission to sync states."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Step 4: Group ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 4: Retrieve Group ID"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Send a text message to the group after adding your bot.\n2. Open your web browser and visit the following URL (replace with your Bot Token):\nhttps://api.telegram.org/bot[YOUR_BOT_TOKEN]/getUpdates\n3. Look for 'chat':{'id':-100xxxxxx} in the response. Copy the complete ID, including the minus sign (e.g., -1001234567890)."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Step 5: App setup & permissions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Step 5: Complete Setup &amp; Permissions"
                    android:textColor="@color/romantic_light_pink"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Install the app on both devices and configure them using the SAME Bot Token and Group ID.\n2. Grant the requested Usage Access and Notification permissions when prompted.\n3. To ensure uninterrupted background sync, disable battery optimizations (set to Unrestricted/Don't Optimize) in Android settings."
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer Credit -->
    <LinearLayout
        android:id="@+id/tv_instructions_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical|center_horizontal"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#FF4081"
            android:alpha="0.8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💗"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_instructions_footer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💗"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#FF4081"
            android:alpha="0.8" />

    </LinearLayout>

</RelativeLayout>
