<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/welcome_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/animated_gradient"
    android:padding="24dp">

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottom_actions_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Grant Access"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            android:backgroundTint="@color/romantic_pink" />

        <!-- Custom Styled Footer Credit -->
        <LinearLayout
            android:id="@+id/tv_welcome_credit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|center_horizontal"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true">

            <View
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="#FF4081"
                android:alpha="0.8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💗"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />

            <TextView
                android:id="@+id/tv_welcome_credit_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💗"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

            <View
                android:layout_width="30dp"
                android:layout_height="1dp"
                android:background="#FF4081"
                android:alpha="0.8" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Click to view Privacy Policy"
            android:textColor="@color/romantic_light_pink"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_actions_layout"
        android:layout_alignParentTop="true"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp">

            <!-- Title and Subtitle Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:gravity="center">

                <!-- App Logo Image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/app_logo"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle"
                    app:strokeColor="@color/romantic_pink"
                    app:strokeWidth="2.5dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="App Logo" />

                <TextView
                    android:id="@+id/app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MyDuo"
                    android:textSize="40sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Only you and your partner. Safe &amp; Shared."
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/gray_light" />
            </LinearLayout>

            <!-- Glassmorphic Card representing step-by-step permissions -->
            <LinearLayout
                android:id="@+id/permission_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/glass_card"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/permission_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usage Stats Access"
                    android:textSize="22sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/permission_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="This is required to monitor the foreground app state changes. MyDuo will only monitor standard app changes (e.g. opening YouTube or Chrome) and encrypts it locally before sending. Your conversations and private content are never read."
                    android:textSize="15sp"
                    android:textColor="@color/gray_light"
                    android:lineSpacingExtra="4dp"
                    android:gravity="center" />

                <!-- Indicator dots to show step progress -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="32dp">

                    <View
                        android:id="@+id/dot_usage"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="@color/romantic_light_pink"
                        android:layout_margin="4dp" />

                    <View
                        android:id="@+id/dot_notif"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="@color/glass_card_stroke"
                        android:layout_margin="4dp" />

                    <View
                        android:id="@+id/dot_foreground"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="@color/glass_card_stroke"
                        android:layout_margin="4dp" />

                    <View
                        android:id="@+id/dot_battery"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="@color/glass_card_stroke"
                        android:layout_margin="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>
