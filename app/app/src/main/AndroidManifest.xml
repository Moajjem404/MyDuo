<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network Access -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Background Execution -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- App state tracking -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />
    
    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MyDuoApplication"
        android:allowBackup="false"
        android:icon="@drawable/app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyDuo">

        <!-- Splash Activity (Main Launcher) -->
        <activity
            android:name=".ui.welcome.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home Dashboard Activity -->
        <activity
            android:name=".ui.home.MainActivity"
            android:exported="false" />

        <!-- Welcome & Permissions Activity -->
        <activity
            android:name=".ui.welcome.WelcomeActivity"
            android:exported="false" />

        <!-- Instructions Setup Guide Activity -->
        <activity
            android:name=".ui.instructions.InstructionsActivity"
            android:exported="false" />

        <!-- Setup Configuration Activity -->
        <activity
            android:name=".ui.setup.SetupActivity"
            android:exported="false" />

        <!-- Settings Settings Activity -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false" />

        <!-- Profile Page Activity -->
        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false" />

        <!-- Activity History Page -->
        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false" />

        <!-- App tracking background service -->
        <service
            android:name=".service.ActivityMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Activity sync and couple notifications service" />
        </service>

        <!-- Boot Broadcast Receiver -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>